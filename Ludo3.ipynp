    def dice_roll(self):
        # Add the roll_dice code here (same as before)
        if self.turn_count < self.max_turns:  # Check if the game is still ongoing
            if self.current_player == 1:
                dice_result = random.randint(1, 6)
                self.player1_score += dice_result
                self.player1_score_label.config(text=f"Total Score: {self.player1_score}")
            else:
                dice_result = random.randint(1, 6)
                self.player2_score += dice_result
                self.player2_score_label.config(text=f"Total Score: {self.player2_score}")

            self.turn_count += 1

            if self.turn_count == self.max_turns:
                self.declare_winner()
            else:
                self.switch_player()


    def switch_player(self):
        # Add the switch_player code here (same as before)
        self.current_player = 3 - self.current_player  # Switch between player 1 and player 2
        
    def declare_winner(self):
        # Add the declare_winner code here (same as before)
        winner = self.player1_name if self.player1_score > self.player2_score else self.player2_name if self.player2_score > self.player1_score else "It's a tie!"
        winner_label = ttk.Label(self.master, text=f"The winner is {winner}!", font=("Helvetica", 18), foreground="blue" if winner != "It's a tie!" else "black")
        winner_label.place(relx=0.35, rely=0.70, relwidth=0.3)

        play_again_button = ttk.Button(self.master, text="Play Again", command=self.reset_game)
        play_again_button.place(relx=0.3, rely=0.80, relwidth=0.4)

    def reset_game(self):
        # Add the reset_game code here (same as before)
        self.player1_name = ""
        self.player2_name = ""
        self.player1_score = 0
        self.player2_score = 0
        self.turn_count = 0
        self.current_player = 1

        for widget in self.master.winfo_children():
            widget.destroy()

        self.create_game_options_screen()



