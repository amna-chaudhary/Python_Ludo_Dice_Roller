    def start_game_if_names_given(self):
        # Add the start_game_if_names_given code here (same as before)
        # Get player names
        self.player1_name = self.player1_entry.get()
        self.player2_name = self.player2_entry.get()

        # Check if both player names are given
        if self.player1_name and self.player2_name:
            # Destroy the current screen and show the game interface
            for widget in self.master.winfo_children():
                widget.destroy()
            self.create_interface()
        else:
            # Display error message if names are not given
            error_label = Label(self.home_frame, text="Please enter names for both players.", font=("Helvetica", 12), fg="red")
            error_label.pack(pady=5)
